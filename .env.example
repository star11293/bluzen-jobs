# Copy this file to .env for local development.
# Real production values live in the Render dashboard, NOT in git.

# Django
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database
# Leave commented to use SQLite locally. Uncomment to test against Postgres.
# DATABASE_URL=postgres://user:pass@localhost:5432/bluzen_jobs

# Email
DEFAULT_FROM_EMAIL=Bluzen Healthcare Staffing <noreply@bluzenhealthcarestaffing.com>

